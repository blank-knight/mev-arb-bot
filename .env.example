# ========================================
# MEV 套利机器人 - 环境变量配置
# 复制此文件为 .env 并填写实际值
# ========================================

# ---- Optimism 链配置 ----
OPTIMISM_RPC_HTTP=https://opt-sepolia.g.alchemy.com/v2/YOUR_API_KEY
OPTIMISM_RPC_WS=wss://opt-sepolia.g.alchemy.com/v2/YOUR_API_KEY
OPTIMISM_CHAIN_ID=11155420
# 主网时改为:
# OPTIMISM_RPC_HTTP=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# OPTIMISM_RPC_WS=wss://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# OPTIMISM_CHAIN_ID=10

# ---- 钱包配置 ----
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# ---- Optimism DEX 合约地址 ----
# Uniswap V3
UNISWAP_V3_QUOTER=0x61fFE014bA17989E743c5F6cB21bF9697530B21e
UNISWAP_V3_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564
UNISWAP_V3_FACTORY=0x1F98431c8aD98523631AE4a59f267346ea31F984
# Velodrome V2
VELODROME_ROUTER=0xa062aE8A9c5e11aaA026fc2670B0D65cCc8B2858
VELODROME_FACTORY=0xF1046053aa5682b4F9a81b5481394DA16BE5FF5a

# ---- Optimism 代币地址 ----
WETH_ADDRESS=0x4200000000000000000000000000000000000006
USDC_ADDRESS=0x0b2C639c533813f4Aa9D7837CAf62653d097Ff85
OP_ADDRESS=0x4200000000000000000000000000000000000042
USDT_ADDRESS=0x94b008aA00579c1307B0EF2c499aD98a8ce58e58

# ---- 套利合约地址（部署后填入，为空则 dry-run 模式）----
ARBITRAGE_CONTRACT=

# ---- 套利策略配置 ----
MIN_PROFIT_THRESHOLD=0.003
MAX_SLIPPAGE=0.003
MAX_TRADE_AMOUNT=1000
MIN_TRADE_AMOUNT=10

# ---- Gas 配置 ----
GAS_PRICE_STRATEGY=dynamic
MAX_GAS_PRICE=0.5

# ---- 日志配置 ----
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/bot.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# ---- Telegram 通知 ----
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ENABLED=false

# 通知开关（true/false）
NOTIFY_ON_TRADE=true
NOTIFY_ON_ERROR=true
NOTIFY_ON_STARTUP=true

# Telegram 统计报告间隔（秒），0 表示不发送
STATS_REPORT_INTERVAL=1800

# ---- 数据库配置 ----
DATABASE_TYPE=sqlite
SQLITE_DATABASE_PATH=./data/arbitrage.db
